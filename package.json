{
  "name": "puppysplit",
  "module": "src/index.tsx",
  "type": "module",
  "scripts": {
    "db:push": "bunx drizzle-kit push:sqlite",
    "db:studio": "bunx drizzle-kit studio",
    "db:clear": "bun run ./src/db/tools/clearDb.ts",
    "db:seed": "bun run ./src/db/tools/seedDb.ts",
    "dev": "concurrently \"bun run --watch src/index.tsx --host\" \"bun run tw:dev\"",
    "tw": "bunx @tailwindcss/cli -i ./src/styles.css -o ./tailwind-gen/styles.css",
    "tw:dev": "bunx @tailwindcss/cli -i ./src/styles.css -o ./tailwind-gen/styles.css --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit && xss-scan"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@kitajs/ts-html-plugin": "^4.1.4",
    "@tailwindcss/cli": "^4.3.0",
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@elysiajs/html": "^1.4.2",
    "@kitajs/html": "^4.2.13",
    "@libsql/client": "^0.17.3",
    "@sinclair/typebox": "^0.34.49",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28"
  }
}